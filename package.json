{
  "name": "sonixd-redux",
  "productName": "Sonixd Redux",
  "description": "Sonixd Redux",
  "scripts": {
    "build": "concurrently \"yarn build:main\" \"yarn build:renderer\" \"yarn build:preload\"",
    "build:main": "cross-env NODE_ENV=production webpack --config ./.erb/configs/webpack.config.main.prod.mjs",
    "build:preload": "cross-env NODE_ENV=production webpack --config ./.erb/configs/webpack.config.preload.mjs",
    "build:renderer": "cross-env NODE_ENV=production webpack --config ./.erb/configs/webpack.config.renderer.prod.mjs",
    "rebuild": "electron-rebuild --parallel --types prod,dev,optional --module-dir src",
    "lint": "cross-env NODE_ENV=development NODE_OPTIONS=--max-old-space-size=4096 eslint src --cache",
    "package": "yarn build && electron-builder build --publish never",
    "prepare": "husky",
    "postinstall": "node .erb/scripts/CheckNativeDep.mjs && electron-builder install-app-deps && yarn cross-env NODE_ENV=development webpack --config ./.erb/configs/webpack.config.renderer.dev.dll.mjs && opencollective-postinstall && yarn-deduplicate yarn.lock && yarn build:preload",
    "start": "node ./.erb/scripts/CheckPortInUse.mjs && yarn start:renderer",
    "start:main": "cross-env NODE_ENV=development node ./.erb/scripts/StartMainDev.mjs",
    "start:renderer": "cross-env NODE_ENV=development webpack serve --config ./.erb/configs/webpack.config.renderer.dev.mjs",
    "test": "jest",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:report": "playwright show-report e2e/playwright-report",
    "i18next": "i18next -c src/i18n/i18next-parser.config.js"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": ["cross-env NODE_ENV=development eslint --cache"],
    "{*.json,.{babelrc,eslintrc,prettierrc}}": [
      "prettier --ignore-path .eslintignore --parser json --write"
    ],
    "*.{css,scss}": ["prettier --ignore-path .eslintignore --single-quote --write"],
    "*.{html,md,yml}": ["prettier --ignore-path .eslintignore --single-quote --write"]
  },
  "build": {
    "productName": "Sonixd Redux",
    "appId": "org.sonixd-redux",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/",
      "node_modules/",
      "index.html",
      "main.prod.js",
      "*.main.prod.js",
      "preload.prod.js",
      "package.json",
      "img/"
    ],
    "afterPack": ".erb/scripts/ApplyFuses.js",
    "afterSign": ".erb/scripts/Notarize.js",
    "electronVersion": "42.2.0",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": {
        "target": "default",
        "arch": ["arm64", "x64"]
      },
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "linux": {
      "target": ["AppImage", "tar.xz"],
      "category": "AudioVideo"
    },
    "directories": {
      "app": "src",
      "buildResources": "assets",
      "output": "release"
    },
    "extraResources": ["./assets/**"],
    "publish": {
      "provider": "github",
      "owner": "joffrey-b",
      "repo": "Sonixd-Redux"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joffrey-b/Sonixd-Redux.git"
  },
  "author": {
    "name": "joffrey-b",
    "url": "https://github.com/joffrey-b/"
  },
  "contributors": [],
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/joffrey-b/Sonixd-Redux/issues"
  },
  "keywords": ["electron", "react", "typescript"],
  "homepage": "https://github.com/joffrey-b/Sonixd-Redux#readme",
  "jest": {
    "testEnvironment": "jest-environment-jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost/",
      "customExportConditions": ["node", "require", "default"]
    },
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/.erb/mocks/fileMock.js",
      "\\.(css|less|sass|scss)$": "identity-obj-proxy",
      "electron-store": "<rootDir>/.erb/mocks/electronStoreMock.js"
    },
    "setupFiles": ["<rootDir>/.erb/mocks/jestSetup.js"],
    "moduleFileExtensions": ["js", "jsx", "ts", "tsx", "json"],
    "moduleDirectories": ["node_modules", "src/node_modules"],
    "modulePathIgnorePatterns": ["<rootDir>/src/package\\.json"],
    "testPathIgnorePatterns": ["<rootDir>/node_modules/", "<rootDir>/e2e/"],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-hotkeys-hook|array-move|nanoid|format-duration)/)"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.19.1",
    "@babel/plugin-transform-react-constant-elements": "^7.12.1",
    "@babel/plugin-transform-react-inline-elements": "^7.12.1",
    "@babel/plugin-transform-runtime": "^7.12.1",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@babel/register": "^7.12.1",
    "@electron/fuses": "^2.1.2",
    "@electron/notarize": "^3",
    "@electron/rebuild": "^4",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6",
    "@teamsupercell/typings-for-css-modules-loader": "^2.4.0",
    "@testing-library/dom": "^10",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16",
    "@types/discord-rpc": "^4.0.2",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.14.172",
    "@types/md5": "^2.3.1",
    "@types/node": "^25",
    "@types/randomstring": "^1.1.7",
    "@types/react": "~19.2.0",
    "@types/react-dom": "~19.2.0",
    "@types/react-lazy-load-image-component": "^1.5.2",
    "@types/react-slider": "^1.3.1",
    "@types/react-test-renderer": "~19.1.0",
    "@types/react-transition-group": "^4.4.4",
    "@types/react-virtualized-auto-sizer": "^1.0.1",
    "@types/redux-mock-store": "^1.0.3",
    "@types/webpack-env": "^1.15.2",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "axios-mock-adapter": "^2.1.0",
    "babel-jest": "^30",
    "babel-loader": "^10.1.1",
    "babel-plugin-dev-expression": "^0.2.2",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "buffer": "^6.0.3",
    "chalk": "^5",
    "concurrently": "^10",
    "cross-env": "^10",
    "css-loader": "^7",
    "css-minimizer-webpack-plugin": "^8",
    "detect-port": "^2",
    "electron": "42.4.0",
    "electron-builder": "^26.0.0",
    "electron-debug": "^4",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^9",
    "eslint-config-airbnb": "^19",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10",
    "eslint-import-resolver-webpack": "^0.13.0",
    "eslint-plugin-compat": "^7",
    "eslint-plugin-import": "^2.27.0",
    "eslint-plugin-jest": "^29",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-promise": "^7",
    "eslint-plugin-react": "^7.37",
    "eslint-plugin-react-hooks": "^7",
    "file-loader": "^6.0.0",
    "globals": "^17.6.0",
    "husky": "^9",
    "i18next-parser": "^9.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30",
    "jest-environment-jsdom": "^30",
    "less": "^4",
    "less-loader": "^13",
    "lint-staged": "^17",
    "mini-css-extract-plugin": "^2.1.0",
    "opencollective-postinstall": "^2.0.3",
    "prettier": "^3.0.0",
    "react-refresh": "^0.18",
    "react-test-renderer": "^19.0.0",
    "redux-mock-store": "^1.5.4",
    "rimraf": "^6",
    "source-map-support": "^0.5.19",
    "style-loader": "^4",
    "terser-webpack-plugin": "^5.0.3",
    "tsc-silent": "^1.2.1",
    "tsx": "^4",
    "typescript": "^6",
    "url-loader": "^4.1.0",
    "webpack": "^5.5.1",
    "webpack-bundle-analyzer": "^5",
    "webpack-cli": "^7",
    "webpack-dev-server": "^5",
    "webpack-merge": "^6",
    "yarn-deduplicate": "^6"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "@rsuite/icons": "^1.4.0",
    "@tanstack/react-query": "^5",
    "array-move": "^4",
    "axios": "^1.0.0",
    "axios-retry": "^4.0.0",
    "chart.js": "^4",
    "dayjs": "^1.11.21",
    "discord-rpc": "^4.0.1",
    "electron-redux": "^2.0.0",
    "electron-store": "^11.0.0",
    "electron-updater": "^6.8.3",
    "fast-average-color": "^9",
    "format-duration": "^4",
    "i18next": "^26.2.0",
    "image-downloader": "^4.0.3",
    "js-cookie": ">=3.0.7",
    "lodash": "^4.17.21",
    "md5": "^2.3.0",
    "nanoid": "^5",
    "node-mpv": "github:joffrey-b/Node-MPV#sonixd-redux",
    "nodejs-fs-utils": "^1.2.5",
    "pako": "^2.1.0",
    "randomstring": "^1.2.1",
    "react": "^19.0.0",
    "react-audio-player": "^0.17.0",
    "react-chartjs-2": "^5",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3",
    "react-hotkeys-hook": "^5.3.2",
    "react-i18next": "^17.0.8",
    "react-lazy-load-image-component": "^1.5.1",
    "react-redux": "^9.0.0",
    "react-router-dom": "^7.0.0",
    "react-slider": "^2.0.0",
    "react-use": "^17.3.2",
    "react-virtualized-auto-sizer": "^2",
    "react-window": "^2",
    "rsuite": "^6.1.3",
    "styled-components": "^6"
  },
  "resolutions": {
    "@types/react": "~19.2.0",
    "glob-parent": "^6",
    "js-cookie": ">=3.0.7",
    "styled-components": "^6",
    "uuid": ">=11.1.1"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.0.0"
    }
  },
  "browserslist": ["Chrome >= 130"],
  "renovate": {
    "extends": ["bliss"],
    "baseBranches": ["main"]
  },
  "engines": {
    "node": ">=24.0.0",
    "yarn": ">=1.22.0"
  }
}
